# Set in CI/CD before npm run build (public in bundle — API URLs only, not secrets)

VITE_APPHUB_BACKEND_URL=https://api.yourcompany.com/api/knf/apphub
VITE_APPHUB_CORE_URL=https://api.yourcompany.com/api/knf

# Parent product origins allowed to postMessage token / language / theme
VITE_APPHUB_PARENT_ORIGINS=https://app.yourcompany.com

# Optional — host integrator internal bridge docs
# VITE_APPHUB_HOST_ACCESS_SECRET=
